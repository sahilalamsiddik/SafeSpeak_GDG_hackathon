# SafeSpeak Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=your_mongodb_connection_string_here
# Local example: mongodb://localhost:27017/safespeak
# Atlas example: mongodb+srv://username:password@cluster.mongodb.net/safespeak

# JWT Secret
JWT_SECRET=replace_with_a_strong_random_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# IP Hashing Salt
IP_SALT=replace_with_a_strong_random_salt

# Optional: File upload size limit (in MB)
MAX_FILE_SIZE_MB=50
